{"resources":[{"id":1949,"title":"DVBSnoop","url":"http://dvbsnoop.sourceforge.net/","description":"An analyzer and debugging tool for MPEG transport streams and DVB broadcasts. It allows inspection of packet structure, tables (PAT, PMT, etc.), and payload of digital video streams.","category":"Media Tools","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["analysis","debugging","transport-stream","dvb","mpeg","inspection"],"sourceCategories":["media-tools"]},"createdAt":"2026-06-01T22:38:09.609Z","updatedAt":"2026-06-01T22:38:09.609Z"},{"id":1948,"title":"DTube","url":"https://d.tube/","description":"A decentralized video platform built on blockchain (Steem/LBRY), offering an alternative to YouTube where videos are distributed via a peer-to-peer network and blockchain stores metadata and rewards.","category":"Infrastructure & Delivery","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["blockchain","decentralized","peer-to-peer","video platform","distributed infrastructure"],"sourceCategories":["infrastructure-delivery"]},"createdAt":"2026-06-01T22:38:09.608Z","updatedAt":"2026-06-01T22:38:09.608Z"},{"id":1947,"title":"PyAV","url":"https://github.com/PyAV-Org/PyAV","description":"A Pythonic binding for FFmpeg’s libraries (Libav). PyAV allows Python programs to read, write, and manipulate video and audio data by leveraging the powerful FFmpeg backend.","category":"Encoding & Codecs","subcategory":"Encoding Tools","subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["ffmpeg","python","encoding","video-processing","library"],"sourceCategories":["encoding-tools"]},"createdAt":"2026-06-01T22:38:09.608Z","updatedAt":"2026-06-01T22:38:09.608Z"},{"id":1946,"title":"MMAction2","url":"https://github.com/open-mmlab/mmaction2","description":"An open source toolkit for video understanding by OpenMMLab. It supports state-of-the-art models for action recognition, temporal action detection, and spatio-temporal detection in videos.","category":"Media Tools","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["machine learning","computer vision","action recognition","video analysis","AI"],"sourceCategories":["media-tools"]},"createdAt":"2026-06-01T22:38:09.607Z","updatedAt":"2026-06-01T22:38:09.607Z"},{"id":1945,"title":"libmpeg2","url":"http://libmpeg2.sourceforge.net/","description":"A free library for decoding MPEG-1 and MPEG-2 video streams. It's lightweight and portable, used in several open source media players for MPEG-2 playback.","category":"Encoding & Codecs","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["codec","mpeg","decoding","library","open-source"],"sourceCategories":["encoding-codecs"]},"createdAt":"2026-06-01T22:38:09.607Z","updatedAt":"2026-06-01T22:38:09.607Z"},{"id":1944,"title":"Jubler","url":"http://www.jubler.org/","description":"A cross-platform open source subtitle editor written in Java. It supports multiple subtitle formats, style editing, timing synchronization, and real-time preview of subtitles on video.","category":"Media Tools","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["subtitles","editor","java","cross-platform","media-processing"],"sourceCategories":["media-tools"]},"createdAt":"2026-06-01T22:38:09.606Z","updatedAt":"2026-06-01T22:38:09.606Z"},{"id":1943,"title":"scikit-video","url":"https://github.com/aizvorski/scikit-video","description":"A set of video processing routines for use with SciPy, providing basic video reading and writing capabilities for scientific computing workflows in Python.","category":"Encoding & Codecs","subcategory":"Encoding Tools","subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["python","video-processing","scientific-computing","library","video-tools"],"sourceCategories":["encoding-tools"]},"createdAt":"2026-06-01T22:38:09.606Z","updatedAt":"2026-06-01T22:38:09.606Z"},{"id":1942,"title":"video4j","url":"https://github.com/metaloom/video4j","description":"A Java video processing library providing a set of tools and APIs to handle video operations in Java applications.","category":"Encoding & Codecs","subcategory":"Encoding Tools","subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["java","library","video-processing","encoding","video-tools"],"sourceCategories":["encoding-tools"]},"createdAt":"2026-06-01T22:38:09.605Z","updatedAt":"2026-06-01T22:38:09.605Z"},{"id":1941,"title":"VLMC (VideoLAN Movie Creator)","url":"https://www.videolan.org/vlmc/","description":"An experimental non-linear video editing software from the VideoLAN project. Aims to offer basic editing (cutting, transitions, etc.) with a simple interface, built on libVLC.","category":"Encoding & Codecs","subcategory":"Encoding Tools","subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["video editing","libVLC","non-linear editing","open source"],"sourceCategories":["encoding-tools"]},"createdAt":"2026-06-01T22:38:09.605Z","updatedAt":"2026-06-01T22:38:09.605Z"},{"id":1940,"title":"ButtleOFX","url":"https://github.com/ButtleOFX/ButtleOFX","description":"An open source nodal video compositing software built on top of OpenFX. It provides a user-friendly interface to apply and connect video effects (an experimental alternative to commercial compositors).","category":"Encoding & Codecs","subcategory":"Encoding Tools","subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["compositing","open-source","video-effects","OpenFX","video-processing"],"sourceCategories":["encoding-tools"]},"createdAt":"2026-06-01T22:38:09.605Z","updatedAt":"2026-06-01T22:38:09.605Z"},{"id":1939,"title":"FFV1 Codec","url":"https://ffmpeg.org/~michael/ffv1.html","description":"FFmpeg’s FFV1 is a lossless intra-frame video codec. It’s open, extremely efficient for archiving video, and is defined in an ongoing standardization (supported by archival institutions).","category":"Encoding & Codecs","subcategory":"Codecs","subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["lossless","archival","ffmpeg","codec","video compression"],"sourceCategories":["codecs"]},"createdAt":"2026-06-01T22:38:09.604Z","updatedAt":"2026-06-01T22:38:09.604Z"},{"id":1938,"title":"UT Video Codec Suite","url":"http://umezawa.dyndns.info/wordpress/?page_id=67","description":"An open source lossless video codec from Umezawa that provides fast encoding/decoding and is often used for lossless video compression on Windows (supports RGB and YUV formats).","category":"Encoding & Codecs","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["codec","lossless","compression","windows","RGB","YUV"],"sourceCategories":["encoding-codecs"]},"createdAt":"2026-06-01T22:38:09.604Z","updatedAt":"2026-06-01T22:38:09.604Z"},{"id":1937,"title":"Lagarith Lossless Codec","url":"https://lags.leetcode.net/codec.html","description":"A lossless video codec for Windows that offers high compression ratios. Useful for archival and intermediate video editing workflows where quality must be preserved (open source).","category":"Encoding & Codecs","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["codec","lossless","compression","windows","open-source","archival"],"sourceCategories":["encoding-codecs"]},"createdAt":"2026-06-01T22:38:09.604Z","updatedAt":"2026-06-01T22:38:09.604Z"},{"id":1936,"title":"CineForm SDK","url":"https://gopro.github.io/cineform-sdk/","description":"GoPro’s CineForm codec SDK, open-sourced, providing tools and libraries for the CineForm HD wavelet-based video codec used for high-fidelity video compression.","category":"Encoding & Codecs","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["codec","sdk","compression","video-encoding","gopro"],"sourceCategories":["encoding-codecs"]},"createdAt":"2026-06-01T22:38:09.603Z","updatedAt":"2026-06-01T22:38:09.603Z"},{"id":1935,"title":"multicat","url":"https://www.videolan.org/projects/multicat.html","description":"A set of lightweight tools for multicast and transport stream manipulation (from the VLC project) – used for efficient UDP streaming, recording, and conversion of TS streams.","category":"Protocols & Transport","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["multicast","UDP","transport stream","streaming","VLC"],"sourceCategories":["protocols-transport"]},"createdAt":"2026-06-01T22:38:09.603Z","updatedAt":"2026-06-01T22:38:09.603Z"},{"id":1934,"title":"FreeJ","url":"https://github.com/freej/freej","description":"A real-time video mixer (VJ tool) that allows compositing multiple video inputs (live capture, movies, images) with layers and effects, controllable via command-line or Joystick (Linux).","category":"Media Tools","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["video mixer","VJ tool","real-time compositing","linux","video effects"],"sourceCategories":["media-tools"]},"createdAt":"2026-06-01T22:38:09.602Z","updatedAt":"2026-06-01T22:38:09.602Z"},{"id":1933,"title":"Content Delivery Video Library (CDVL)","url":"https://www.cdvl.org/","description":"An online library of test video content and sequences provided for researchers and developers to evaluate video processing and streaming techniques (various resolutions, formats, and scenarios).","category":"Media Tools","subcategory":"Ads & QoE","subSubcategory":"Quality & Testing","status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["video testing","research","evaluation","video sequences","resolution testing"],"sourceCategories":["quality-testing"]},"createdAt":"2026-06-01T22:38:09.602Z","updatedAt":"2026-06-01T22:38:09.602Z"},{"id":1932,"title":"Light Alloy","url":"https://light-alloy.com/","description":"A lightweight, freeware media player for Windows known for its fast startup and support of all common video formats with configurable keyboard shortcuts.","category":"Players & Clients","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["media player","windows","video playback","freeware"],"sourceCategories":["players-clients"]},"createdAt":"2026-06-01T22:38:09.602Z","updatedAt":"2026-06-01T22:38:09.602Z"},{"id":1931,"title":"MP4Joiner & MP4Splitter","url":"https://www.mp4joiner.org/en/","description":"Free open-source tools to losslessly join and split MP4 files without re-encoding. Useful for simple video file merging and cutting tasks.","category":"Encoding & Codecs","subcategory":"Encoding Tools","subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["mp4","video-editing","lossless","file-manipulation","open-source"],"sourceCategories":["encoding-tools"]},"createdAt":"2026-06-01T22:38:09.601Z","updatedAt":"2026-06-01T22:38:09.601Z"},{"id":1930,"title":"go2rtc","url":"https://github.com/AlexxIT/go2rtc","description":"A flexible high-performance streaming server written in Go that can ingest RTSP, WebRTC, RTMP, HTTP-FLV, and LL-HLS and output streams to multiple protocols (commonly used for home camera streaming).","category":"Infrastructure & Delivery","subcategory":"Streaming Servers","subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["rtsp","webrtc","rtmp","streaming","server","go","home-camera"],"sourceCategories":["streaming-servers"]},"createdAt":"2026-06-01T22:38:09.601Z","updatedAt":"2026-06-01T22:38:09.601Z"}],"total":1949}