Protocols & Transport journey","resourceIds":["https://github.com/pion/webrtc","https://www.videolan.org/projects/dvblast.html"],"estimatedHours":5,"order":4}],"prerequisites":["Basic networking knowledge","Web development basics"],"learningObjectives":["Understand HLS and DASH protocols","Set up a streaming infrastructure","Implement ABR streaming","Monitor stream quality and performance"],"generationType":"template","matchScore":75},{"id":"template_path_1780443453379","title":"Web Video Player Development","description":"Build custom video players for web applications","difficulty":"intermediate","estimatedDuration":"25h","category":"Players & Clients","resources":[{"id":1839,"title":"Kodi Add-ons (PVR IPTV Simple Client)","url":"https://kodi.tv/addons","description":"An example official Kodi add-on that allows playing live TV streams via IPTV. Kodi's rich add-on ecosystem includes clients for various streaming protocols, enabling Kodi to serve as a full-fledged PVR.","category":"Players & Clients","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["media player","IPTV","streaming client","open source"],"sourceCategories":["players-clients"]},"createdAt":"2026-06-01T22:38:09.564Z","updatedAt":"2026-06-01T22:38:09.564Z"},{"id":1549,"title":"Bitmovin Test Stream","url":"https://bitmovin.com/demos/stream-test","description":"Bitmovin's Test Player allows users to experience their HTML5 video player demo, showcasing adaptive streaming capabilities.","category":"Players & Clients","subcategory":"Mobile & Web Players","subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["html5","player","adaptive streaming","web player","demo"],"sourceCategories":["mobile-web-players"]},"createdAt":"2026-06-01T22:38:09.445Z","updatedAt":"2026-06-01T22:38:09.445Z"},{"id":1932,"title":"Light Alloy","url":"https://light-alloy.com/","description":"A lightweight, freeware media player for Windows known for its fast startup and support of all common video formats with configurable keyboard shortcuts.","category":"Players & Clients","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["media player","windows","video playback","freeware"],"sourceCategories":["players-clients"]},"createdAt":"2026-06-01T22:38:09.602Z","updatedAt":"2026-06-01T22:38:09.602Z"},{"id":1911,"title":"OMXPlayer","url":"https://github.com/popcornmix/omxplayer","description":"A hardware-accelerated command-line video player for the Raspberry Pi that utilizes the Pi’s GPU decoding for smooth playback.","category":"Players & Clients","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["raspberry-pi","command-line","video-player","hardware-acceleration","gpu-decoding"],"sourceCategories":["players-clients"]},"createdAt":"2026-06-01T22:38:09.593Z","updatedAt":"2026-06-01T22:38:09.593Z"},{"id":1910,"title":"Xine","url":"http://xine.sourceforge.net/","description":"An open source multimedia playback engine and player for Unix-like systems, featuring support for CD/DVD playback and a wide range of codecs.","category":"Players & Clients","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["open-source","multimedia","player","unix","codec-support","playback-engine"],"sourceCategories":["players-clients"]},"createdAt":"2026-06-01T22:38:09.593Z","updatedAt":"2026-06-01T22:38:09.593Z"},{"id":1909,"title":"MediaPortal","url":"https://www.team-mediaportal.com/","description":"An open source media center 