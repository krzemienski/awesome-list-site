[{"id":"template_path_1780443450806","title":"Video Encoding Fundamentals","description":"Master the basics of video encoding, codecs, and compression techniques","difficulty":"beginner","estimatedDuration":"15h","category":"Encoding & Codecs","resources":[{"id":1675,"title":"FFmpeg Wiki: Filtering Guide","url":"https://trac.ffmpeg.org/wiki/FilteringGuide","description":"Documentation on using FFmpeg’s filtering system, demonstrating how to chain video filters (scale, crop, overlay, etc.) and audio filters for processing media with examples.","category":"Encoding & Codecs","subcategory":"Encoding Tools","subSubcategory":"FFMPEG","status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["ffmpeg","video filtering","documentation","tutorial","media processing"],"sourceCategories":["ffmpeg"]},"createdAt":"2026-06-01T22:38:09.495Z","updatedAt":"2026-06-01T22:38:09.495Z"},{"id":1756,"title":"AV1 vs HEVC – Bitmovin Compression Efficiency Results","url":"https://bitmovin.com/av1-showing-greater-compression-efficiency-than-hevc/","description":"A Bitmovin blog post that discusses internal testing results comparing AV1 and HEVC encoders. It provides charts and analysis of bitrate savings, encoding speed, and visual quality, contributing practical data to the conversation about next-gen codec adoption.","category":"Encoding & Codecs","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["codec","compression","AV1","HEVC","bitrate","encoding","comparison"],"sourceCategories":["encoding-codecs"]},"createdAt":"2026-06-01T22:38:09.529Z","updatedAt":"2026-06-01T22:38:09.529Z"},{"id":1719,"title":"AOMedia AV1 Codec Build Instructions","url":"https://aomedia.googlesource.com/aom/+/refs/heads/master/BUILD.md","description":"Documentation for building the AOMedia AV1 codec library (libaom) from source on various platforms. It's a useful reference for developers wanting to compile the latest AV1 encoder/decoder and integrate it into their workflows or products.","category":"Encoding & Codecs","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["codec","AV1","libaom","build instructions","encoder","decoder"],"sourceCategories":["encoding-codecs"]},"createdAt":"2026-06-01T22:38:09.514Z","updatedAt":"2026-06-01T22:38:09.514Z"},{"id":1945,"title":"libmpeg2","url":"http://libmpeg2.sourceforge.net/","description":"A free library for decoding MPEG-1 and MPEG-2 video streams. It's lightweight and portable, used in several open source media players for MPEG-2 playback.","category":"Encoding & Codecs","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["codec","mpeg","decoding","library","open-source"],"sourceCategories":["encoding-codecs"]},"createdAt":"2026-06-01T22:38:09.607Z","updatedAt":"2026-06-01T22:38:09.607Z"},{"id":1939,"title":"FFV1 Codec","url":"https://ffmpeg.org/~michael/ffv1.html","description":"FFmpeg’s FFV1 is a lossless intra-frame video codec. It’s open, extremely efficient for archiving video, and is defined in an ongoing standardization (supported by archival institutions).","category":"Encoding & Codecs","subcategory":"Codecs","subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["lossless","archival","ffmpeg","codec","video compression"],"sourceCategories":["codecs"]},"createdAt":"2026-06-01T22:38:09.604Z","updatedAt":"2026-06-01T22:38:09.604Z"},{"id":1938,"title":"UT Video Codec Suite","url":"http://umezawa.dyndns.info/wordpress/?page_id=67","description":"An open source lossless video codec from Umezawa that provides fast encoding/decoding and is often used for lossless video compression on Windows (supports RGB and YUV formats).","category":"Encoding & Codecs","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["codec","lossless","compression","windows","RGB","YUV"],"sourceCategories":["encoding-codecs"]},"createdAt":"2026-06-01T22:38:09.604Z","updatedAt":"2026-06-01T22:38:09.604Z"},{"id":1937,"title":"Lagarith Lossless Codec","url":"https://lags.leetcode.net/codec.html","description":"A lossless video codec for Windows that offers high compression ratios. Useful for archival and intermediate video editing workflows where quality must be preserved (open source).","category":"Encoding & Codecs","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["codec","lossless","compression","windows","open-source","archival"],"sourceCategories":["encoding-codecs"]},"createdAt":"2026-06-01T22:38:09.604Z","updatedAt":"2026-06-01T22:38:09.604Z"},{"id":1936,"title":"CineForm SDK","url":"https://gopro.github.io/cineform-sdk/","description":"GoPro’s CineForm codec SDK, open-sourced, providing tools and libraries for the CineForm HD wavelet-based video codec used for high-fidelity video compression.","category":"Encoding & Codecs","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["codec","sdk","compression","video-encoding","gopro"],"sourceCategories":["encoding-codecs"]},"createdAt":"2026-06-01T22:38:09.603Z","updatedAt":"2026-06-01T22:38:09.603Z"}],"milestones":[{"id":"milestone_1","title":"Understanding video basics and terminology","description":"Complete this milestone to progress in your Encoding & Codecs journey","resourceIds":["https://trac.ffmpeg.org/wiki/FilteringGuide","https://bitmovin.com/av1-showing-greater-compression-efficiency-than-hevc/"],"estimatedHours":3.75,"order":1},{"id":"milestone_2","title":"Learning about common codecs (H.264, H.265, AV1)","description":"Complete this milestone to progress in your Encoding & Codecs journey","resourceIds":["https://aomedia.googlesource.com/aom/+/refs/heads/master/BUILD.md","http://libmpeg2.sourceforge.net/"],"estimatedHours":3.75,"order":2},{"id":"milestone_3","title":"Hands-on encoding with FFmpeg","description":"Complete this milestone to progress in your Encoding & Codecs journey","resourceIds":["https://ffmpeg.org/~michael/ffv1.html","http://umezawa.dyndns.info/wordpress/?page_id=67"],"estimatedHours":3.75,"order":3},{"id":"milestone_4","title":"Optimizing quality vs file size","description":"Complete this milestone to progress in your Encoding & Codecs journey","resourceIds":["https://lags.leetcode.net/codec.html","https://gopro.github.io/cineform-sdk/"],"estimatedHours":3.75,"order":4}],"prerequisites":["Basic computer skills","Interest in video technology"],"learningObjectives":["Understand how video compression works","Choose the right codec for your needs","Use FFmpeg for basic encoding tasks","Optimize video quality and file size"],"generationType":"template","matchScore":75},{"id":"template_path_1780443451968","title":"Live Streaming Basics","description":"Learn the fundamentals of live streaming protocols and technologies","difficulty":"beginner","estimatedDuration":"20h","category":"Protocols & Transport","resources":[{"id":1710,"title":"Wowza Ultra Low Latency CMAF Guide","url":"https://www.wowza.com/docs/using-cmaf-for-low-latency-streaming","description":"A guide from Wowza on using CMAF for low-latency streaming. It explains how CMAF enables low-latency modes in HLS and DASH by using chunked transfer encoding and provides configuration tips for achieving sub-2-second latency.","category":"Protocols & Transport","subcategory":"Adaptive Streaming","subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["CMAF","low-latency","HLS","DASH","streaming","chunked encoding"],"sourceCategories":["adaptive-streaming"]},"createdAt":"2026-06-01T22:38:09.509Z","updatedAt":"2026-06-01T22:38:09.509Z"},{"id":1935,"title":"multicat","url":"https://www.videolan.org/projects/multicat.html","description":"A set of lightweight tools for multicast and transport stream manipulation (from the VLC project) – used for efficient UDP streaming, recording, and conversion of TS streams.","category":"Protocols & Transport","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["multicast","UDP","transport stream","streaming","VLC"],"sourceCategories":["protocols-transport"]},"createdAt":"2026-06-01T22:38:09.603Z","updatedAt":"2026-06-01T22:38:09.603Z"},{"id":1928,"title":"PeerJS","url":"https://peerjs.com/","description":"A simple peer-to-peer JavaScript library that abstracts WebRTC for direct video, audio, and data connectivity between browsers. Provides an easy way to build video chat and P2P apps.","category":"Protocols & Transport","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["WebRTC","peer-to-peer","real-time communication","browser technology"],"sourceCategories":["protocols-transport"]},"createdAt":"2026-06-01T22:38:09.600Z","updatedAt":"2026-06-01T22:38:09.600Z"},{"id":1922,"title":"coturn","url":"https://github.com/coturn/coturn","description":"An open source implementation of TURN and STUN servers, used to facilitate NAT traversal for peer-to-peer video (and audio) communication in WebRTC and other protocols.","category":"Protocols & Transport","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["WebRTC","NAT","network","transport","peer-to-peer","communication"],"sourceCategories":["protocols-transport"]},"createdAt":"2026-06-01T22:38:09.598Z","updatedAt":"2026-06-01T22:38:09.598Z"},{"id":1920,"title":"aiortc (Python WebRTC)","url":"https://github.com/aiortc/aiortc","description":"A Python library for Web Real-Time Communication that implements WebRTC and ORTC, enabling real-time audio/video and data streaming in Python applications.","category":"Protocols & Transport","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["WebRTC","real-time","streaming","Python","transport","communication"],"sourceCategories":["protocols-transport"]},"createdAt":"2026-06-01T22:38:09.597Z","updatedAt":"2026-06-01T22:38:09.597Z"},{"id":1919,"title":"Peer5 HLS P2P","url":"https://docs.peer5.com/","description":"Peer5’s peer-to-peer content delivery solution for HLS streams. It uses WebRTC to distribute video segments among viewers to offload bandwidth from the CDN.","category":"Protocols & Transport","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["HLS","WebRTC","P2P","content delivery","streaming protocol"],"sourceCategories":["protocols-transport"]},"createdAt":"2026-06-01T22:38:09.597Z","updatedAt":"2026-06-01T22:38:09.597Z"},{"id":1872,"title":"Pion WebRTC","url":"https://github.com/pion/webrtc","description":"A pure Go implementation of the WebRTC protocol, enabling developers to build real-time video (and audio) streaming applications without external dependencies.","category":"Protocols & Transport","subcategory":null,"