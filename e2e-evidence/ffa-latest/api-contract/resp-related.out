{"resources":[{"id":1946,"title":"MMAction2","url":"https://github.com/open-mmlab/mmaction2","description":"An open source toolkit for video understanding by OpenMMLab. It supports state-of-the-art models for action recognition, temporal action detection, and spatio-temporal detection in videos.","category":"Media Tools","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["machine learning","computer vision","action recognition","video analysis","AI"],"sourceCategories":["media-tools"]},"createdAt":"2026-06-01T22:38:09.607Z","updatedAt":"2026-06-01T22:38:09.607Z"},{"id":1944,"title":"Jubler","url":"http://www.jubler.org/","description":"A cross-platform open source subtitle editor written in Java. It supports multiple subtitle formats, style editing, timing synchronization, and real-time preview of subtitles on video.","category":"Media Tools","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["subtitles","editor","java","cross-platform","media-processing"],"sourceCategories":["media-tools"]},"createdAt":"2026-06-01T22:38:09.606Z","updatedAt":"2026-06-01T22:38:09.606Z"},{"id":1934,"title":"FreeJ","url":"https://github.com/freej/freej","description":"A real-time video mixer (VJ tool) that allows compositing multiple video inputs (live capture, movies, images) with layers and effects, controllable via command-line or Joystick (Linux).","category":"Media Tools","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["video mixer","VJ tool","real-time compositing","linux","video effects"],"sourceCategories":["media-tools"]},"createdAt":"2026-06-01T22:38:09.602Z","updatedAt":"2026-06-01T22:38:09.602Z"},{"i