{"resources":[{"id":1944,"title":"Jubler","url":"http://www.jubler.org/","description":"A cross-platform open source subtitle editor written in Java. It supports multiple subtitle formats, style editing, timing synchronization, and real-time preview of subtitles on video.","category":"Media Tools","subcategory":null,"subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["subtitles","editor","java","cross-platform","media-processing"],"sourceCategories":["media-tools"]},"createdAt":"2026-06-01T22:38:09.606Z","updatedAt":"2026-06-01T22:38:09.606Z"},{"id":1943,"title":"scikit-video","url":"https://github.com/aizvorski/scikit-video","description":"A set of video processing routines for use with SciPy, providing basic video reading and writing capabilities for scientific computing workflows in Python.","category":"Encoding & Codecs","subcategory":"Encoding Tools","subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["python","video-processing","scientific-computing","library","video-tools"],"sourceCategories":["encoding-tools"]},"createdAt":"2026-06-01T22:38:09.606Z","updatedAt":"2026-06-01T22:38:09.606Z"},{"id":1942,"title":"video4j","url":"https://github.com/metaloom/video4j","description":"A Java video processing library providing a set of tools and APIs to handle video operations in Java applications.","category":"Encoding & Codecs","subcategory":"Encoding Tools","subSubcategory":null,"status":"approved","submittedBy":null,"approvedBy":null,"approvedAt":null,"githubSynced":false,"lastSyncedAt":null,"metadata":{"tags":["java","library","video-processing","encoding","video-tools"],"sourceCategories":["encoding-tools"]},"createdAt":"2026-06-01T22:38:09.605Z","updatedAt":"2026-06-01T22:38:09.605Z"},{"id":1941,"title":"VLMC (VideoLAN Movie Creator)","url":"https://www.