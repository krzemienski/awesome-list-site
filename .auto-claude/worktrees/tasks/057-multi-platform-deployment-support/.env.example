# ===========================================
# Awesome List Site - Environment Variables
# ===========================================
# Copy this file to .env and configure for your environment
# Never commit your .env file to version control

# ===========================================
# Database Configuration (REQUIRED)
# ===========================================

# PostgreSQL connection string
# For Neon: postgresql://user:password@host/database?sslmode=require
# For local Docker: postgresql://postgres:postgres@localhost:5432/awesome_list_site
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/awesome_list_site

# ===========================================
# Server Configuration
# ===========================================

# Environment mode: development | production
NODE_ENV=development

# Server port (optional, defaults to 5000)
# Production platforms like Replit Autoscale and Vercel set this automatically
PORT=5000

# ===========================================
# Content Configuration
# ===========================================

# URL for awesome-go raw content (optional)
# Default: https://raw.githubusercontent.com/avelino/awesome-go/main/README.md
# AWESOME_RAW_URL=https://raw.githubusercontent.com/avelino/awesome-go/main/README.md

# GitHub repository URL for contributions (optional)
# Used for generating contribution links
# GITHUB_REPO_URL=https://github.com/username/awesome-list-site

# ===========================================
# Platform-Specific Configuration
# ===========================================

# Replit deployment (optional, auto-detected on Replit)
# Only needed if deploying on Replit
# REPL_ID=your-repl-id

# ===========================================
# Future/Optional Features
# ===========================================

# Session security (planned feature)
# Generate with: openssl rand -base64 32
# SESSION_SECRET=your-secret-key-change-this-in-production

# AI features (planned feature)
# ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key

# GitHub integration (planned feature)
# GITHUB_TOKEN=your-github-token

# Replit OAuth (planned feature, not needed for most deployments)
# ISSUER_URL=your-issuer-url
